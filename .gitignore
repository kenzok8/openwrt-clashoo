# 内核二进制
root/etc/clash/clash
root/etc/clash/clash-meta
root/usr/bin/mihomo
root/usr/bin/clash*

# GeoIP / GeoSite 数据
root/etc/clash/Country.mmdb
root/etc/clash/*.dat

# 中国 IP 列表（运行时下载）
root/usr/share/clash/china_ip.txt
root/usr/share/clash/china_ipv6.txt

# 运行时日志/状态
root/usr/share/clash/clash.txt
root/usr/share/clash/clash_real.txt
root/usr/share/clash/logstatus_check

# 用户订阅配置
root/etc/clash/config.yaml
root/etc/clash/custom/
root/usr/share/clash/config/

# yacd/dashboard 面板（运行时安装）
root/usr/share/clash/yacd/
root/usr/share/clash/dashboard/

# macOS
.DS_Store

# build artifacts
dist/

# local test helpers
test-http/

# runtime generated state files
root/usr/share/clash/new_*
root/usr/share/clash/*_version
root/usr/share/clash/fake_filter.list
root/usr/share/clash/rules/

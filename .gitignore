clashoo/root/usr/share/clash/china_ipv6.txt
clashoo/core/mihomo/*/mihomo

# ── 运行时日志 / 状态 ──
clashoo/root/usr/share/clash/clash.txt
clashoo/root/usr/share/clash/clash_real.txt
clashoo/root/usr/share/clash/logstatus_check
clashoo/root/usr/share/clash/new_*
clashoo/root/usr/share/clash/*_version
clashoo/root/usr/share/clash/fake_filter.list
clashoo/root/usr/share/clash/rules/

# ── 用户订阅 / 配置（严禁入库） ──
clashoo/root/etc/clash/config.yaml
clashoo/root/etc/clash/custom/
clashoo/root/usr/share/clash/config/
clashoo/files/usr/share/clashoo/config/
*.subscribe
*.subscription

# ── 运行时安装的面板 ──
clashoo/root/usr/share/clash/yacd/
clashoo/root/usr/share/clash/dashboard/

